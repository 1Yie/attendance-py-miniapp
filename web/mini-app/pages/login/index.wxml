<view class="page-shell login-page">
  <navigation-bar title="考勤打卡" back="{{false}}" color="#172033" background="#eef3f9"></navigation-bar>

  <view class="login-hero">
    <text class="login-hero__title">登录</text>
    <text class="login-hero__title">开始今天的打卡</text>
  </view>

  <view class="page-body login-page__body">
    <view class="card shadow-soft login-card">
      <view class="field">
        <text class="label">手机号</text>
        <input
          class="input"
          type="number"
          maxlength="11"
          placeholder="请输入 11 位中国大陆手机号"
          value="{{form.phone}}"
          bindinput="handlePhoneInput"
        />
      </view>

      <view class="field login-card__field-gap">
        <text class="label">密码</text>
        <input
          class="input"
          password="{{true}}"
          placeholder="请输入登录密码"
          value="{{form.password}}"
          bindinput="handlePasswordInput"
        />
      </view>

      <button class="btn-primary login-card__button" loading="{{submitting}}" bindtap="handleLogin">
        登录
      </button>
    </view>
  </view>
</view>
