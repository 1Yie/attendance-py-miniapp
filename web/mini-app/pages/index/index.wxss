.clock-page {
  background: linear-gradient(180deg, #eef3f9 0%, #e9f0f8 100%);
}

.clock-hero {
  background: linear-gradient(135deg, #16294a 0%, #2154ff 55%, #1ea7ff 100%);
  color: #ffffff;
}

.clock-hero__title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.clock-hero__desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 24rpx;
}

.clock-hero__tag {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
}

.clock-hero__date {
  display: block;
  margin-top: 34rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
}

.clock-hero__time {
  display: block;
  margin-top: 12rpx;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.clock-config {
  margin-top: 34rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
}

.clock-config__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.clock-config__item .label,
.clock-config__item .value {
  color: #ffffff;
}

.clock-config__divider {
  width: 2rpx;
  height: 74rpx;
  background: rgba(255, 255, 255, 0.18);
  margin: 0 20rpx;
}

.clock-actions {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
}

.clock-actions__button {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.clock-actions__button + .clock-actions__button {
  margin-left: 18rpx;
}

.clock-actions__button-light {
  background: rgba(255, 255, 255, 0.92);
}

.clock-section {
  margin-top: 24rpx;
}

.clock-shortcut-card__button {
  min-width: 160rpx;
  height: 72rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.clock-record {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.clock-record__title,
.clock-latest__title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.clock-record__meta,
.clock-latest__meta {
  display: block;
  margin-top: 10rpx;
  color: #7d8aa2;
  font-size: 24rpx;
}

.clock-latest__title {
  margin-top: 26rpx;
}

.clock-skeleton__hero-copy {
  flex: 1;
}

.clock-skeleton__date {
  width: 34%;
  margin-top: 34rpx;
}

.clock-skeleton__time {
  width: 54%;
  height: 88rpx;
  margin-top: 16rpx;
  border-radius: 20rpx;
}

.clock-skeleton__record-copy {
  flex: 1;
}
