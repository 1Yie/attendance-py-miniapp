page {
  height: 100vh;
  background: #eef3f9;
  color: #172033;
  font-size: 28rpx;
}

view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

.page-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
}

.page-body {
  padding: 28rpx 24rpx 180rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(39, 76, 119, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.section-subtitle {
  color: #6c7a92;
  font-size: 24rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-success {
  color: #0b7a42;
  background: #e7f8ef;
}

.badge-warning {
  color: #a85b00;
  background: #fff3de;
}

.badge-danger {
  color: #b42318;
  background: #feeceb;
}

.badge-neutral {
  color: #465467;
  background: #edf1f6;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border: none;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #2255ff 0%, #22a2ff 100%);
  color: #ffffff;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border: 2rpx solid #d4deea;
  border-radius: 24rpx;
  background: #ffffff;
  color: #172033;
}

.empty-state {
  padding: 56rpx 24rpx;
  text-align: center;
  color: #7d8aa2;
  font-size: 26rpx;
}

.label {
  color: #7d8aa2;
  font-size: 24rpx;
}

.value {
  color: #172033;
  font-size: 30rpx;
  font-weight: 600;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.input {
  width: 100%;
  height: 92rpx;
  border: 2rpx solid #dce4ef;
  border-radius: 22rpx;
  padding: 0 24rpx;
  background: #f8fbff;
}

.link-text {
  color: #2255ff;
}

.muted {
  color: #7d8aa2;
}

.divider {
  height: 2rpx;
  background: #edf1f6;
}

.shadow-soft {
  box-shadow: 0 14rpx 40rpx rgba(24, 53, 91, 0.12);
}

.skeleton-block {
  position: relative;
  overflow: hidden;
  background: #e8eef6;
  border-radius: 20rpx;
}

.skeleton-block::after {
  content: '';
  position: absolute;
  top: 0;
  left: -150%;
  width: 120%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.72) 50%, rgba(255, 255, 255, 0) 100%);
  animation: skeleton-shimmer 1.4s infinite;
}

.skeleton-text {
  height: 24rpx;
  border-radius: 999rpx;
}

.skeleton-text--sm {
  width: 32%;
}

.skeleton-text--md {
  width: 56%;
}

.skeleton-text--lg {
  width: 78%;
}

.skeleton-text--xl {
  width: 100%;
}

.skeleton-pill {
  width: 120rpx;
  height: 44rpx;
  border-radius: 999rpx;
}

.skeleton-button {
  flex: 1;
  height: 84rpx;
  border-radius: 24rpx;
}

.skeleton-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.skeleton-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.skeleton-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

@keyframes skeleton-shimmer {
  0% {
    left: -150%;
  }

  100% {
    left: 150%;
  }
}

.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.button-reset {
  margin: 0;
  padding: 0;
  line-height: normal;
  background: transparent;
  border: none;
}

.button-reset::after {
  border: none;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
  box-sizing: border-box;
}
